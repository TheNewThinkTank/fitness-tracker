# Required environment variables for fitness-tracker
# Copy this file to .env and fill in your values.

# Your OS username (used to construct paths)
USER=your_username

# Your email address (used for Google API auth)
EMAIL=you@example.com

# Athlete identifier (used as folder name in Google Drive data path)
# e.g. "john_doe"
ATHLETE=your_athlete_name

# Path to the root of your local workout data directory.
# In CI / local dev without Google Drive, set this to the bundled data/ folder:
#   GOOGLE_DRIVE_DATA_PATH=data
# In production, set it to the full Google Drive path:
#   GOOGLE_DRIVE_DATA_PATH=/Users/you/Library/CloudStorage/GoogleDrive-.../My Drive/DATA/fitness-tracker-data
GOOGLE_DRIVE_DATA_PATH=data
